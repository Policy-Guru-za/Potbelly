{
  "name": "potbelly",
  "private": true,
  "version": "2.0.0",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "setup:python": "python3 -m venv .venv && .venv/bin/python -m pip install --disable-pip-version-check -r requirements.lock",
    "build": "pnpm build:assets && pnpm build:content && pnpm build:sw",
    "build:assets": "vite build",
    "build:content": "DYLD_FALLBACK_LIBRARY_PATH=${DYLD_FALLBACK_LIBRARY_PATH:-/opt/homebrew/lib} XDG_CACHE_HOME=${XDG_CACHE_HOME:-$PWD/.cache} .venv/bin/python build.py --output dist --site-url ${SITE_URL:-http://127.0.0.1:4173}",
    "build:sw": "vite build --config vite.sw.config.ts && node scripts/inject-service-worker.mjs",
    "check": "pnpm worker:types && pnpm typecheck && pnpm lint && .venv/bin/python -m compileall -q build.py potbelly pipeline scripts tests && .venv/bin/python -m scripts.validate_corpus",
    "typecheck": "tsc --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "lint": "eslint src worker tests/unit --max-warnings=0",
    "test": ".venv/bin/python -m unittest discover -v && vitest run && pnpm test:worker",
    "test:unit": "vitest run",
    "test:worker": "OPENAI_API_KEY=test-only AI_RATE_LIMIT_HASH_SECRET=test-only AI_ENABLED=false vitest run --config worker/vitest.config.mts",
    "test:e2e": "mkdir -p .cache/tmp && TMPDIR=$PWD/.cache/tmp playwright test",
    "verify:links": ".venv/bin/python -m scripts.check_links dist --site-url ${SITE_URL:-http://127.0.0.1:4173}",
    "verify:ai-health": "node scripts/verify-ai-health.mjs",
    "verify:sources": ".venv/bin/python -m scripts.check_sources",
    "verify": "pnpm check && pnpm test && pnpm build && pnpm test:e2e && pnpm verify:links",
    "dev": "pnpm build && .venv/bin/python tests/serve_static.py",
    "worker:dev": "wrangler dev --config worker/wrangler.jsonc",
    "worker:types": "wrangler types worker/worker-configuration.d.ts --config worker/wrangler.jsonc --env production --include-runtime false --check",
    "worker:deploy:staging": "wrangler deploy --config worker/wrangler.jsonc --env staging",
    "worker:deploy:production": "wrangler deploy --config worker/wrangler.jsonc --env production",
    "pipeline:dry-run": ".venv/bin/python pipeline/expand_corpus.py --dry-run --target 150",
    "pipeline:migrate-cache": ".venv/bin/python pipeline/migrate_cache.py",
    "pipeline:validate-output": ".venv/bin/python pipeline/validate_output.py --target 150",
    "pipeline:expand": ".venv/bin/python pipeline/expand_corpus.py --target 150"
  },
  "dependencies": {
    "@openai/agents": "0.13.2",
    "idb": "8.0.3",
    "openai": "6.46.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@cloudflare/workers-types": "5.20260713.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "workbox-build": "7.4.1",
    "workbox-core": "7.4.1",
    "workbox-expiration": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1",
    "workbox-strategies": "7.4.1",
    "wrangler": "4.110.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd"],
    "overrides": {
      "@tootallnate/once@<2.0.1": "2.0.1",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "js-yaml@>=4.0.0 <=4.1.1": "4.2.0",
      "minimatch@>=10.0.0 <10.2.3": "10.2.5",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.2",
      "smol-toml@<1.6.1": "1.6.1",
      "tar@<7.5.20": "7.5.20",
      "undici@<6.27.0": "6.27.0"
    }
  }
}
